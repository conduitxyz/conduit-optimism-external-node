# =============================================================================
# Optimism Chain Replica Nodes Configuration
# =============================================================================
# Copy this file to .env and update values for your chain
# =============================================================================

# IMAGE VERSIONS
# -------------
OP_GETH_VERSION=v1.101605.0
OP_NODE_VERSION=v1.16.5
CELESTIA_DA_SERVER_VERSION=0.9.0
EIGENDA_PROXY_VERSION=2.4.1

OP_NODE_ROLLUP_CONFIG=/config/rollup.json
OP_NODE_P2P_SYNC_ONLYREQTOSTATIC=true

# NETWORK CONFIGURATION (set by download-config.sh)
# --------------------
OP_NODE_P2P_STATIC=
OP_NODE_P2P_BOOTNODES=
OP_NODE_P2P_ADVERTISE_IP=
OP_GETH_SEQUENCER_HTTP=

# FORK TIMESTAMP OVERRIDES (set by download-config.sh)
# ---------------------------------------------------
GETH_OVERRIDE_CANYON=
GETH_OVERRIDE_ECOTONE=
GETH_OVERRIDE_FJORD=
GETH_OVERRIDE_GRANITE=
GETH_OVERRIDE_HOLOCENE=
GETH_OVERRIDE_ISTHMUS=
GETH_OVERRIDE_JOVIAN=
OP_NODE_OVERRIDE_CANYON=
OP_NODE_OVERRIDE_DELTA=
OP_NODE_OVERRIDE_ECOTONE=
OP_NODE_OVERRIDE_FJORD=
OP_NODE_OVERRIDE_GRANITE=
OP_NODE_OVERRIDE_HOLOCENE=
OP_NODE_OVERRIDE_ISTHMUS=
OP_NODE_OVERRIDE_JOVIAN=

# SYNC CONFIGURATION
# -----------------
OP_NODE_SYNCMODE=consensus-layer

# [REQUIRED] L1 CONFIGURATION
# --------------------------
# Replace these values with your L1 (Ethereum) node endpoints
OP_NODE_L1_ETH_RPC=
OP_NODE_L1_BEACON=

# ENGINE CONFIGURATION
# -------------------
OP_NODE_L2_ENGINE_AUTH=/tmp/engine-auth-jwt

# P2P CONFIGURATION
# ---------------
OP_NODE_P2P_LISTEN_IP=0.0.0.0
OP_NODE_P2P_LISTEN_TCP_PORT=9222
OP_NODE_P2P_LISTEN_UDP_PORT=9222

# RPC CONFIGURATION
# ---------------
OP_NODE_RPC_ADDR=0.0.0.0
OP_NODE_RPC_PORT=8545

# LOGGING & MONITORING
# ------------------
OP_NODE_LOG_LEVEL=info
OP_NODE_LOG_FORMAT="json"
OP_NODE_SNAPSHOT_LOG=/tmp/op-node-snapshot-log

#ENABLE FOR ALT DA (CELESTIA/EIGENDA)
# ---------------
# OP_ALTDA_LOG_LEVEL=debug
# OP_NODE_ALTDA_VERIFY_ON_READ=false

#CELESTIA DA SPECIFIC CONFIGURATION 
# ---------------
# CELESTIA_RPC=
# CELESTIA_AUTH_TOKEN=
# CELESTIA_NAMESPACE=

#EIGENDA SPECIFIC CONFIGURATION
# ---------------
# EIGENDA_DIRECTORY=
# EIGENDA_PROXY_EIGENDA_V2_CERT_VERIFIER_ROUTER_OR_IMMUTABLE_VERIFIER_ADDR=
# EIGENDA_PROXY_STORAGE_BACKENDS_TO_ENABLE=V2
# EIGENDA_PROXY_STORAGE_DISPERSAL_BACKEND=V2
# EIGENDA_PROXY_EIGENDA_V2_DISPERSER_RPC=